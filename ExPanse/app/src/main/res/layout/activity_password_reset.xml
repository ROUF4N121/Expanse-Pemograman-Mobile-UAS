<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:fontFamily="@font/montserrat_bold"
        android:text="@string/password_reset_title"
        android:textColor="#000000"
        android:textSize="28sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/montserrat_regular"
        android:text="@string/password_reset_subtitle"
        android:textAlignment="center"
        android:textColor="#424242"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <LinearLayout
        android:id="@+id/llOtpContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle">

        <EditText android:id="@+id/otp1" android:layout_width="55dp" android:layout_height="65dp" android:layout_marginEnd="8dp" android:background="@drawable/bg_input" android:fontFamily="@font/montserrat_regular" android:gravity="center" android:inputType="number" android:maxLength="1" android:textSize="24sp" android:textColor="#000000" />
        <EditText android:id="@+id/otp2" android:layout_width="55dp" android:layout_height="65dp" android:layout_marginEnd="8dp" android:background="@drawable/bg_input" android:fontFamily="@font/montserrat_regular" android:gravity="center" android:inputType="number" android:maxLength="1" android:textSize="24sp" android:textColor="#000000" />
        <EditText android:id="@+id/otp3" android:layout_width="55dp" android:layout_height="65dp" android:layout_marginEnd="8dp" android:background="@drawable/bg_input" android:fontFamily="@font/montserrat_regular" android:gravity="center" android:inputType="number" android:maxLength="1" android:textSize="24sp" android:textColor="#000000" />
        <EditText android:id="@+id/otp4" android:layout_width="55dp" android:layout_height="65dp" android:background="@drawable/bg_input" android:fontFamily="@font/montserrat_regular" android:gravity="center" android:inputType="number" android:maxLength="1" android:textSize="24sp" android:textColor="#000000" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnContinue"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:layout_marginTop="32dp"
        android:backgroundTint="#FFA500"
        android:fontFamily="@font/montserrat_bold"
        android:text="@string/continue_btn"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        app:cornerRadius="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llOtpContainer" />

    <LinearLayout
        android:id="@+id/llResend"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnContinue">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/montserrat_regular"
            android:text="@string/didnt_receive_email"
            android:textColor="#888888"
            android:textSize="12sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:fontFamily="@font/montserrat_regular"
            android:text="@string/click_here"
            android:textColor="#2980B9"
            android:textSize="12sp" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBackToLoginOtp"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="#FFFFFF"
        android:fontFamily="@font/montserrat_bold"
        android:text="@string/back_to_login"
        android:textAllCaps="false"
        android:textColor="#000000"
        android:textSize="14sp"
        app:cornerRadius="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llResend"
        app:strokeColor="#CCCCCC"
        app:strokeWidth="1dp" />

</androidx.constraintlayout.widget.ConstraintLayout>